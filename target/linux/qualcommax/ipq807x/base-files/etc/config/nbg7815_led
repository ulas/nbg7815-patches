config global 'main'
	option enabled '1'
	option boot_timeout '30'
	option refresh_interval '10'
	option night_mode '1'
	option night_start '23:00'
	option night_end '07:00'
	option wan_interface 'wan'
	option overtemp_threshold '85000'
	option usb_notify_seconds '2'

config state 'normal'
	option enabled '1'
	option priority '10'
	option bank 'q1'
	option channel '0'
	option pattern '11'
	option night_policy 'hide'

config state 'internet_down'
	option enabled '1'
	option priority '20'
	option bank 'q1'
	option channel '0'
	option pattern '22'
	option night_policy 'show'

config state 'boot'
	option enabled '1'
	option priority '30'
	option bank 'q1'
	option channel '0'
	option pattern '11'
	option night_policy 'show'

config state 'usb_notify'
	option enabled '1'
	option priority '35'
	option bank 'q1'
	option channel '1'
	option pattern '20'
	option night_policy 'show'

config state 'wps'
	option enabled '1'
	option priority '40'
	option bank 'q1'
	option channel '2'
	option pattern '18'
	option night_policy 'show'

config state 'overtemp'
	option enabled '1'
	option priority '50'
	option bank 'q2'
	option channel '0'
	option pattern '14'
	option night_policy 'show'

config state 'reset_pending'
	option enabled '1'
	option priority '60'
	option bank 'q2'
	option channel '1'
	option pattern '09'
	option night_policy 'show'

config state 'upgrade'
	option enabled '1'
	option priority '90'
	option bank 'q1'
	option channel '1'
	option pattern '20'
	option night_policy 'show'

config state 'failsafe'
	option enabled '1'
	option priority '100'
	option bank 'q2'
	option channel '2'
	option pattern '14'
	option night_policy 'show'
