config wifi-device 'radio0'
	option type 'mac80211'
	option path 'platform/soc@0/c000000.wifi'
	option band '5g'
	option channel 'auto'
	option htmode 'HE160'
	option country 'PA'
	option cell_density '3'
	option txpower '30'

config wifi-iface 'default_radio0'
	option device 'radio0'
	option network 'lan'
	option mode 'ap'
	option ssid 'NBG7815 5GHz'
	option encryption 'none'
	option disabled '0'

config wifi-device 'radio1'
	option type 'mac80211'
	option path 'platform/soc@0/c000000.wifi+1'
	option band '2g'
	option channel 'auto'
	option htmode 'HE40'
	option country 'PA'
	option cell_density '3'
	option legacy_rates '1'
	option txpower '30'

config wifi-iface 'default_radio1'
	option device 'radio1'
	option network 'lan'
	option mode 'ap'
	option ssid 'NBG7815 2.4GHz'
	option encryption 'none'
	option disabled '0'
